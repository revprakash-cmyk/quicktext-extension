{
  "manifest_version": 3,
  "name": "QuickText",
  "version": "0.1.0",
  "description": "Free browser text expansion tool",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/popup.html"
  },

  "options_page": "src/options/options.html",

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}